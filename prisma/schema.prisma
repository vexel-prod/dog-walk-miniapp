generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id                 String   @id @default(cuid())
  offerId            String
  offerTitle         String
  offerPrice         String
  walkDateLabel      String?
  walkPeriodLabel    String?
  buyerName          String
  buyerUsername      String?
  buyerTelegramId    String?
  status             String   @default("pending")
  notificationStatus String   @default("pending")
  notificationError  String?
  buyerNotificationStatus String @default("pending")
  buyerNotificationError  String?
  decisionAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
